{
  "name": "redharness",
  "version": "1.0.1",
  "description": "Agent evaluation, regression, & safe red-team security harness with app-specific QA packs",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsx src/cli.ts",
    "qa": "tsx src/cli.ts",
    "build": "tsc --project tsconfig.build.json",
    "verify:built": "node dist/src/cli.js list pocket-socrates --json",
    "release:ci": "tsx src/cli.ts release-profile fixture-web --fixture --profile release --run-id fixture-web-release --output-dir artifacts/release-profile",
    "verify": "npm run typecheck && npm test && npm run build && npm run verify:built",
    "save-auth": "tsx src/saveAuth.ts",
    "save-auth-cdp": "tsx src/saveAuthFromCdp.ts"
  },
  "keywords": [
    "qa",
    "testing",
    "regression",
    "security",
    "pentest",
    "red-team",
    "agent-evaluation",
    "agentic-testing"
  ],
  "author": "AIWhispererDev",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AIWhispererDev/redharness.git"
  },
  "homepage": "https://github.com/AIWhispererDev/redharness#readme",
  "bugs": {
    "url": "https://github.com/AIWhispererDev/redharness/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "redharness": "./dist/src/cli.js",
    "qa-harness": "./dist/src/cli.js"
  },
  "files": [
    "dist/",
    "packs/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "commander": "^15.0.0",
    "playwright": "^1.60.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
